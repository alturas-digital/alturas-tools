# Copiá este archivo como .env.local para desarrollo local
# En Railway: Settings → Variables → agregar DATABASE_URL

# Railway Postgres — lo encontrás en tu proyecto de Railway:
# Dashboard → Postgres → Connect → "Postgres Connection URL"
DATABASE_URL=postgresql://user:password@host:5432/railway

# Google PageSpeed Insights API (gratis — console.cloud.google.com)
GOOGLE_PAGESPEED_API_KEY=AIzaSy...

# TODO sesión 3: agregar RESEND_API_KEY para envío de emails
# RESEND_API_KEY=re_xxxxxxxxxxxx
